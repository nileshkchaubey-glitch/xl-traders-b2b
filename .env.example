# ====== XL Traders — copy to .env, fill, and NEVER commit .env ======

# ---- REQUIRED: Supabase (get from Supabase Dashboard → Settings → API) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# SECRET (service_role) key — full admin access. Local scripts only.
# ⚠️ NEVER expose this in client-side code or VITE_ prefixed vars.
SUPABASE_SERVICE_ROLE_KEY=paste-your-service-role-key-here

SUPABASE_BUCKET=product-images

# ---- OPTIONAL: AI description proxy ----
# Point this to YOUR backend endpoint that proxies Anthropic/OpenAI requests.
# Never expose third-party API keys in the browser.
# VITE_AI_PROXY_URL=https://your-backend.example.com/api/ai/describe

# ---- OPTIONAL: AI image generation (server-side only) ----
# IMAGE_GEN_URL=https://api.openai.com/v1/images/generations
# IMAGE_GEN_KEY=your-image-api-key
# IMAGE_GEN_MODEL=gpt-image-1
# IMAGE_GEN_SIZE=1024x1024
